#!/bin/bash

# Check for -debug flag
if [[ $* == *-debug* ]]; then
    set -x
fi

export LGR_NO_TIMESTAMP=true

GIT_MAIN="main"
VERSION_FILE="./.version"

# Get the directory where this script is located
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# If we have a .taskenv file load it as source
# the file should be e.g.
# #!/bin/bash
# export DATABASE_URL="..."
if [ -f .taskenv ]; then
    # shellcheck disable=SC1091
    source .taskenv
fi

# This makes all bin packages installed via npm available here
# e.g. bogota, nyc, autocannon, etc.
PATH=$(pwd)/node_modules/.bin:$PATH

# This will make all scripts available in the ./src/bin directory
PATH=$(pwd)/src/bin:$PATH


#################################################
# Development dependencies
#################################################

function _install:lgr {
    mkdir -p bin
    if hash lgr 2>/dev/null; then
        lgr OK "lgr already installed..."
    else
        if [[ $(command -v brew) == "" ]]; then
            echo "Installing lgr"
            brew tap goliatone/homebrew-tap
            brew install lgr
            lgr OK "lgr installed..."
        else
            LGR_VERSION="0.1.1"
            LGR_FILENAME="lgr_${LGR_VERSION}_linux_x86_64.tar.gz"
            curl -sL "https://github.com/goliatone/lgr/releases/download/v${LGR_VERSION}/${LGR_FILENAME}" | tar xz
            chmod +x lgr
            lgr OK "lgr installed"
        fi
    fi
}

function _install:changelog {
    if git-cliff lgr 2>/dev/null; then
        lgr OK "git-cliff already installed..."
    else
        echo "Installing lgr"
        brew install brew install orhun/git-cliff/git-cliff
        lgr OK "git-cliff installed..."
    fi
}

function _install:brew {
    if [[ $(command -v brew) == "" ]]; then
        lgr I "Installing Hombrew"
        /usr/bin/ruby -e "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install)"
    else
        lgr I "Updating Homebrew"
        brew update
    fi
}

function _install:envset {
    if hash envset 2>/dev/null; then
        lgr OK "envset installed..."
    else
        lgr I "Installing envset..."
        brew install envset
        lgr OK "envset installed..."
    fi
}

function lgr {
  if command -v lgr >/dev/null 2>&1; then
    command lgr "$@"
  else
    printf '%s\n' "$*"
  fi
}

##########################################
# Application management
##########################################

function dev:install {
    cd "$(pwd)/src" || exit "$?"

    _install:lgr
    _install:brew

    _install:envset
    _install:changelog

    lgr ok "dependencies intalled..."
}

function dev:env:load {
    eval "$(envset development --isolated=true)"
}

##
## ########################################
##           Version Management
## ########################################

##
## -----
##
## version:upsert
##
## Save version to meta file.
## First time will create file if not present
##
## Arguments:
## @arg 1 {string} [tag=0.0.1]
function version:upsert {
    local tag=${1}

    if [ -z "$tag" ]; then
        version:get
    else
        version:set "$tag"
        version:get
    fi
}

##
## -----
##
## version:get
##
## Get version from meta file.
function version:get {

    test -f "${VERSION_FILE}" || touch "${VERSION_FILE}"

    local tag
    tag=$(cat "${VERSION_FILE}")

    if [ -z "$tag" ]; then
        tag="0.0.1"
        version:set "$tag"
    fi

    echo -n "$tag"
}

##
## -----
##
## version:set
##
## Set and save version to meta file.
## First time will create file if not present.
##
## Arguments:
## @arg 1 {string} [tag=0.0.1]
function version:set {

    local tag
    tag=${1}
    if [ -z "$tag" ]; then
        exit 1
    fi

    version:check

    echo -e "$tag" > "${VERSION_FILE}"
}

##
## -----
##
## version:bump
## Bump sem ver by specifying a level.
## Valid levels are:
## - patch (default)
## - minor
## - major
##
## If you want to update the .version file
## pass the `--write` flag.
## @see https://github.com/fsaintjacques/semver-tool/blob/master/src/semver
##
## @arg 1 {string} [level=patch]
## Outputs:
##   Semver string "$major.$minor.$patch"
##
## @flag --write Will write to .version file
##
function version:bump {

    version:check

    # Default values
    level='patch'
    write_to_file=0

    # Parse options
    while [[ "$#" -gt 0 ]]; do
        case $1 in
            --write)
                write_to_file=1
                shift
            ;;
            patch|minor|major)
                level=$1
                shift
            ;;
            *)
                echo "Invalid option: $1"
                return 2
            ;;
        esac
    done

    # Read contents of version and store in
    IFS='.' read -ra identifiers < "$VERSION_FILE"

    [[ "${#identifiers[@]}" -ne 3 ]] && echo "Invalid semver string" && return 1

    patch=${identifiers[2]}
    minor=${identifiers[1]}
    major=${identifiers[0]}

    case $level in
        patch)
            patch=$((patch+1))
        ;;
        minor)
            minor=$((minor+1))
            patch=0
        ;;
        major)
            major=$((major+1))
            minor=0
            patch=0
        ;;
        *)
            echo "Invalid level passed"
            return 2
    esac

    new_version="$major.$minor.$patch"

    if [[ $write_to_file -eq 1 ]]; then
        echo "$new_version" > "${VERSION_FILE}"
    else
        echo "$new_version"
    fi
}

function version:check {
    if [ ! -f "$VERSION_FILE" ]; then
        echo "0.0.0" > "$VERSION_FILE"
    fi
}

function release:notes:has_content {
    local file=${1}

    if [ -z "${file}" ] || [ ! -f "${file}" ]; then
        return 1
    fi

    awk 'NF { found = 1; exit } END { exit found ? 0 : 1 }' "${file}"
}

function release:notes:assert_temporary {
    local file=${1}

    if [ -z "${file}" ]; then
        return 0
    fi

    if git ls-files --error-unmatch -- "${file}" >/dev/null 2>&1; then
        echo "Release notes file is tracked; refusing to consume it as temporary notes: ${file}" >&2
        echo "Use an ignored scratch file such as .release-notes.md, or set RELEASE_NOTES_FILE to an untracked path." >&2
        return 1
    fi
}

function release:changelog:generate {
    local release_tag=${1}
    local release_notes_file=${2}
    local release_notes

    if release:notes:has_content "${release_notes_file}"; then
        release:notes:assert_temporary "${release_notes_file}" || return 1
        release_notes=$(cat "${release_notes_file}") || return 1
        git cliff --tag "${release_tag}" --with-tag-message "${release_notes}" --output CHANGELOG.md || return 1
        rm -f "${release_notes_file}" || return 1
        echo "Included and removed temporary release notes: ${release_notes_file}" >&2
        return 0
    fi

    git cliff --tag "${release_tag}" --output CHANGELOG.md
}


##
## -----
##
## release
##
## Bump our current version, create a git tag
## and push to trigger our release flow.
##
## Arguments:
## @arg 1 {string} [level=patch]
##        Accepted major, minor, patch
function release {
    local tag
    local level
    local message
    local current_branch
    local release_tag
    local main_branch="${GIT_MAIN:-main}"
    local release_notes_file
    local release_notes_enabled

    level=""
    message=""
    release_notes_file="${RELEASE_NOTES_FILE:-.release-notes.md}"
    release_notes_enabled=1

    while [[ "$#" -gt 0 ]]; do
        case "$1" in
            patch|minor|major)
                if [ -n "${level}" ]; then
                    echo "Release level specified more than once" >&2
                    return 2
                fi
                level=$1
                shift
            ;;
            --notes|--notes-file)
                shift
                if [ -z "${1:-}" ]; then
                    echo "--notes requires a file path" >&2
                    return 2
                fi
                release_notes_file=$1
                shift
            ;;
            --no-release-notes)
                release_notes_enabled=0
                shift
            ;;
            --)
                shift
                while [[ "$#" -gt 0 ]]; do
                    if [ -z "${message}" ]; then
                        message=$1
                    else
                        message="${message} $1"
                    fi
                    shift
                done
            ;;
            -*)
                echo "Invalid release option: $1" >&2
                return 2
            ;;
            *)
                if [ -z "${message}" ]; then
                    message=$1
                else
                    message="${message} $1"
                fi
                shift
            ;;
        esac
    done

    level=${level:-"patch"}

    current_branch=$(git symbolic-ref --short HEAD) || return 1
    if [[ "${current_branch}" != "${main_branch}" ]]; then
        lgr E "Release must run on ${main_branch}; current branch is ${current_branch}"
        return 1
    fi

    if [ -n "$(git status --porcelain --untracked-files=no)" ]; then
        echo "Tracked working tree changes are present; commit or stash them before release." >&2
        git status --short --untracked-files=no >&2
        return 1
    fi

    git fetch origin "${main_branch}" --tags || return 1
    git merge --ff-only "origin/${main_branch}" || return 1

    tag=$(version:bump "${level}") || return 1
    release_tag="v${tag}"

    if git rev-parse -q --verify "refs/tags/${release_tag}" >/dev/null; then
        echo "Release tag already exists: ${release_tag}" >&2
        return 1
    fi

    message=${message:-"New ${level} release: ${release_tag}"}

    version:set "${tag}" || return 1

    if [ "${release_notes_enabled}" -eq 1 ]; then
        release:changelog:generate "${release_tag}" "${release_notes_file}" || return 1
    else
        git cliff --tag "${release_tag}" --output CHANGELOG.md || return 1
    fi

    git add "${VERSION_FILE}" CHANGELOG.md || return 1
    git commit -m "Bump version: ${release_tag}" || return 1

    git tag -a "${release_tag}" -m "${message}" || return 1

    git push --atomic origin "HEAD:${main_branch}" "refs/tags/${release_tag}" || return 1
}

##########################################
# Help and auxiliary functions
##########################################

## Show function code
function help:show {
    declare -f "$1"
}

function help {
    echo ""
    echo "$0 <task> [...arguments]"
    echo ""
    echo "Project: ${PROJECT}"
    echo ""
    echo "Tasks:"
    compgen -A function | grep -v '^_' | cat -n
    echo ""

    prog="$0"
    me=$(basename "$prog")

    grep -e '^##[[:space:]]' -e '^##$' "$prog" | sed -e 's/^##//' -e "s/_PROG_/$me/" 2>&1 | less
}

TIMEFORMAT="Task completed in %3lR"
time "${@:-help}"