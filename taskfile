#!/bin/bash

# Check for -debug flag
if [[ $* == *-debug* ]]; then
    set -x
fi

export LGR_NO_TIMESTAMP=true

GIT_MAIN="main"
VERSION_FILE="./.version"
GO_NESTED_MODULES="${GO_NESTED_MODULES:-transport/valkey transport/ws adapters/go-command}"
# Quality tools may require a newer compiler than the module's Go baseline.
# Automatic selection applies only to the isolated `go install` invocations.
GO_TOOLCHAIN="${GO_TOOLCHAIN:-auto}"
GO_GOLANGCI_LINT_VERSION="${GO_GOLANGCI_LINT_VERSION:-v2.12.2}"
GO_GOLANGCI_LINT_VERSION_FILE="${GO_GOLANGCI_LINT_VERSION_FILE:-.golangci-lint-version}"
GO_GOVULNCHECK_VERSION="${GO_GOVULNCHECK_VERSION:-v1.1.4}"
GO_GOSEC_VERSION="${GO_GOSEC_VERSION:-v2.25.0}"
GO_QUALITY_GOCACHE="${GO_QUALITY_GOCACHE:-$(pwd)/.tmp/go-cache}"
GO_QUALITY_GOTMPDIR="${GO_QUALITY_GOTMPDIR:-$(pwd)/.tmp/go-tmp}"
GO_LINT_NEW_FROM_REV="${GO_LINT_NEW_FROM_REV:-origin/main}"
GIT_CLIFF_BIN="${GIT_CLIFF_BIN:-git-cliff}"

# Get the directory where this script is located
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# If we have a .taskenv file load it as source
# the file should be e.g.
# #!/bin/bash
# export DATABASE_URL="..."
if [ -f .taskenv ]; then
    # shellcheck disable=SC1091
    source .taskenv
fi

# This makes all bin packages installed via npm available here
# e.g. bogota, nyc, autocannon, etc.
PATH=$(pwd)/node_modules/.bin:$PATH

# This will make all scripts available in the ./src/bin directory
PATH=$(pwd)/src/bin:$PATH


#################################################
# Development dependencies
#################################################

function _install:lgr {
    mkdir -p bin
    if hash lgr 2>/dev/null; then
        lgr OK "lgr already installed..."
    else
        if [[ $(command -v brew) == "" ]]; then
            echo "Installing lgr"
            brew tap goliatone/homebrew-tap
            brew install lgr
            lgr OK "lgr installed..."
        else
            LGR_VERSION="0.1.1"
            LGR_FILENAME="lgr_${LGR_VERSION}_linux_x86_64.tar.gz"
            curl -sL "https://github.com/goliatone/lgr/releases/download/v${LGR_VERSION}/${LGR_FILENAME}" | tar xz
            chmod +x lgr
            lgr OK "lgr installed"
        fi
    fi
}

function _install:changelog {
    if command -v "${GIT_CLIFF_BIN}" >/dev/null 2>&1; then
        lgr OK "git-cliff already installed..."
        return 0
    fi

    echo "Installing git-cliff"
    if command -v brew >/dev/null 2>&1; then
        brew install orhun/git-cliff/git-cliff || return 1
    elif command -v cargo >/dev/null 2>&1; then
        cargo install git-cliff --locked || return 1
    else
        echo "git-cliff is required; install it with Homebrew or Cargo" >&2
        return 1
    fi
    command -v "${GIT_CLIFF_BIN}" >/dev/null 2>&1 || return 1
    lgr OK "git-cliff installed..."
}

function _install:brew {
    if [[ $(command -v brew) == "" ]]; then
        lgr I "Installing Hombrew"
        /usr/bin/ruby -e "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install)"
    else
        lgr I "Updating Homebrew"
        brew update
    fi
}

function _install:envset {
    if hash envset 2>/dev/null; then
        lgr OK "envset installed..."
    else
        lgr I "Installing envset..."
        brew install envset
        lgr OK "envset installed..."
    fi
}

function lgr {
  if command -v lgr >/dev/null 2>&1; then
    command lgr "$@"
  else
    printf '%s\n' "$*"
    fi
}

function _go:bin {
    if command -v go >/dev/null 2>&1; then
        command -v go
        return 0
    fi

    echo "go binary not found in PATH" >&2
    return 1
}

function _go:quality:prepare_env {
    export GOCACHE="${GOCACHE:-${GO_QUALITY_GOCACHE}}"
    export GOTMPDIR="${GOTMPDIR:-${GO_QUALITY_GOTMPDIR}}"
    mkdir -p "${GOCACHE}" "${GOTMPDIR}"
}

function _go:golangci_lint_version {
    if [ -f "${GO_GOLANGCI_LINT_VERSION_FILE}" ]; then
        awk 'NF { print $1; exit }' "${GO_GOLANGCI_LINT_VERSION_FILE}"
        return 0
    fi

    printf '%s\n' "${GO_GOLANGCI_LINT_VERSION}"
}

function _go:tool_bin_dir {
    local go_bin
    local gobin
    local gopath

    go_bin=$(_go:bin) || return 1
    gobin="$("${go_bin}" env GOBIN)"
    if [ -n "${gobin}" ]; then
        printf '%s\n' "${gobin}"
        return 0
    fi

    gopath="$("${go_bin}" env GOPATH)"
    if [ -n "${gopath}" ]; then
        printf '%s\n' "${gopath%/}/bin"
        return 0
    fi

    echo "unable to resolve Go tool bin directory" >&2
    return 1
}

function _go:tool:path {
    local name=$1
    local bin_dir

    bin_dir=$(_go:tool_bin_dir) || return 1
    if [ -x "${bin_dir}/${name}" ]; then
        printf '%s\n' "${bin_dir}/${name}"
        return 0
    fi

    if command -v "${name}" >/dev/null 2>&1; then
        command -v "${name}"
        return 0
    fi

    return 1
}

function _go:tool:matches {
    local tool_path=$1
    local module=$2
    local version=$3
    local go_bin

    go_bin=$(_go:bin) || return 1
    "${go_bin}" version -m "${tool_path}" 2>/dev/null | awk -v module="${module}" -v version="${version}" '
        $1 == "mod" && $2 == module && $3 == version { found = 1 }
        END { exit found ? 0 : 1 }
    '
}

function _go:tool:install {
    local name=$1
    local target=$2
    local bin_dir
    local go_bin

    go_bin=$(_go:bin) || return 1
    bin_dir=$(_go:tool_bin_dir) || return 1
    _go:quality:prepare_env || return 1
    echo "Installing ${name} (${target})" >&2
    GOTOOLCHAIN="${GO_TOOLCHAIN}" "${go_bin}" install "${target}" || return 1
    if [ ! -x "${bin_dir}/${name}" ]; then
        echo "installed ${name} was not found at ${bin_dir}/${name}" >&2
        return 1
    fi
    printf '%s\n' "${bin_dir}/${name}"
}

function _go:tool:ensure {
    local name=$1
    local target=$2
    local module=$3
    local version=$4
    local tool_path

    if tool_path=$(_go:tool:path "${name}" 2>/dev/null); then
        if _go:tool:matches "${tool_path}" "${module}" "${version}"; then
            printf '%s\n' "${tool_path}"
            return 0
        fi
        echo "${name} at ${tool_path} does not match ${module}@${version}" >&2
    fi

    tool_path=$(_go:tool:install "${name}" "${target}") || return 1
    if ! _go:tool:matches "${tool_path}" "${module}" "${version}"; then
        echo "installed ${name} does not match ${module}@${version}" >&2
        return 1
    fi
    printf '%s\n' "${tool_path}"
}

function _go:golangci_lint:ensure {
    local version=$1

    _go:tool:ensure \
        "golangci-lint" \
        "github.com/golangci/golangci-lint/v2/cmd/golangci-lint@${version}" \
        "github.com/golangci/golangci-lint/v2" \
        "${version}"
}

function _go:module_dirs {
    printf '%s\n' "."
    find . -mindepth 2 -type f -name go.mod \
        -not -path './.git/*' \
        -not -path './.tmp/*' \
        -not -path '*/vendor/*' \
        -exec dirname {} \; \
        | sed 's#^\./##' \
        | sort -u
}

function _go:run_in_modules {
    local module

    while IFS= read -r module; do
        if [ "${module}" = "." ]; then
            "$@" || return 1
        else
            (cd "${module}" && "$@") || return 1
        fi
    done < <(_go:module_dirs)
}

function _go:packages {
    local go_bin
    local -a patterns=()

    go_bin=$(_go:bin) || return 1
    if [ "$#" -gt 0 ]; then
        patterns=("$@")
        "${go_bin}" list "${patterns[@]}"
        return 0
    fi

    _go:run_in_modules "${go_bin}" list ./...
}

function _go:files {
    find . -type f -name '*.go' \
        -not -path './.git/*' \
        -not -path './.gocache/*' \
        -not -path './.tmp/*' \
        -not -path '*/vendor/*' \
        | sort
}

function _go:lint:patterns {
    if [ "$#" -gt 0 ]; then
        printf '%s\n' "$@"
        return 0
    fi

    printf '%s\n' "./..."
}

function _go:lint:new_from_rev {
    if git rev-parse --verify --quiet "${GO_LINT_NEW_FROM_REV}^{commit}" >/dev/null; then
        printf '%s\n' "${GO_LINT_NEW_FROM_REV}"
        return 0
    fi

    if [ "${GO_LINT_NEW_FROM_REV}" = "origin/main" ] && git rev-parse --verify --quiet "main^{commit}" >/dev/null; then
        printf '%s\n' "main"
        return 0
    fi

    echo "lint comparison revision not found: ${GO_LINT_NEW_FROM_REV}" >&2
    echo "fetch the base branch or set GO_LINT_NEW_FROM_REV to an existing revision" >&2
    return 1
}

