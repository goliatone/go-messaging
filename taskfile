    while IFS= read -r pattern; do
        if [ -n "${pattern}" ]; then
            patterns+=("${pattern}")
        fi
    done < <(_go:lint:patterns "$@")
    "${golangci_lint_bin}" run --new-from-rev="${new_from_rev}" --whole-files "${patterns[@]}"
}

function go:lint:report {
