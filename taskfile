function go:tools:golangci-lint {
    local version

    version="$(_go:golangci_lint_version)" || return 1
    _go:golangci_lint:ensure "${version}"
}

function go:tools:govulncheck {
    _go:tool:ensure \
        "govulncheck" \
        "golang.org/x/vuln/cmd/govulncheck@${GO_GOVULNCHECK_VERSION}" \
        "golang.org/x/vuln" \
        "${GO_GOVULNCHECK_VERSION}"
}

function go:tools:gosec {
    _go:tool:ensure \
        "gosec" \
        "github.com/securego/gosec/v2/cmd/gosec@${GO_GOSEC_VERSION}" \
        "github.com/securego/gosec/v2" \
        "${GO_GOSEC_VERSION}"
}

function go:tools:all {
    go:tools:golangci-lint || return 1
    go:tools:govulncheck || return 1
    go:tools:gosec || return 1
}

function go:fmt {
    local gofmt_bin
    local -a files=()

    gofmt_bin="$(dirname "$(_go:bin)")/gofmt"
    while IFS= read -r file; do
        if [ -n "${file}" ]; then
            files+=("${file}")
        fi
    done < <(_go:files)
    if [ "${#files[@]}" -eq 0 ]; then
        echo "No Go files found"
        return 0
    fi

    "${gofmt_bin}" -w "${files[@]}"
}

function go:fix {
    local go_bin
    local -a patterns=()

    go_bin=$(_go:bin) || return 1
    _go:quality:prepare_env || return 1
    if [ "$#" -eq 0 ]; then
        _go:run_in_modules "${go_bin}" fix ./...
        return $?
    fi

    while IFS= read -r pattern; do
        if [ -n "${pattern}" ]; then
            patterns+=("${pattern}")
        fi
    done < <(_go:lint:patterns "$@")
    "${go_bin}" fix "${patterns[@]}"
}

function go:fmt:check {
    local gofmt_bin
    local -a files=()
    local unformatted

    gofmt_bin="$(dirname "$(_go:bin)")/gofmt"
    while IFS= read -r file; do
        if [ -n "${file}" ]; then
            files+=("${file}")
        fi
    done < <(_go:files)
    if [ "${#files[@]}" -eq 0 ]; then
        echo "No Go files found"
        return 0
    fi

    unformatted="$("${gofmt_bin}" -l "${files[@]}")"
    if [ -n "${unformatted}" ]; then
        echo "The following Go files need formatting:"
        echo "${unformatted}"
        return 1
    fi
}

