function go:lint:new {
    local golangci_lint_bin
    local new_from_rev
    local version
    local -a patterns=()

    version="$(_go:golangci_lint_version)" || return 1
    golangci_lint_bin=$(_go:golangci_lint:ensure "${version}") || return 1
    new_from_rev=$(_go:lint:new_from_rev) || return 1
    _go:quality:prepare_env || return 1
    if [ "$#" -eq 0 ]; then
        _go:run_in_modules "${golangci_lint_bin}" run --new-from-rev="${new_from_rev}" --whole-files ./...
        return $?
