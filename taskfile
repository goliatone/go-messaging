##
## ########################################
##           Version Management
## ########################################

##
## -----
##
## version:upsert
##
## Save version to meta file.
## First time will create file if not present
##
## Arguments:
## @arg 1 {string} [tag=0.0.1]
function version:upsert {
    local tag=${1}

    if [ -z "$tag" ]; then
        version:get
    else
        version:set "$tag"
        version:get
    fi
}

##
## -----
##
## version:get
##
## Get version from meta file.
function version:get {

    test -f "${VERSION_FILE}" || touch "${VERSION_FILE}"

    local tag
    tag=$(cat "${VERSION_FILE}")

    if [ -z "$tag" ]; then
        tag="0.0.1"
        version:set "$tag"
    fi

    echo -n "$tag"
}

##
## -----
##
## version:set
##
## Set and save version to meta file.
## First time will create file if not present.
##
## Arguments:
## @arg 1 {string} [tag=0.0.1]
function version:set {

    local tag
    tag=${1}
    if [ -z "$tag" ]; then
        exit 1
    fi

    version:check

    echo -e "$tag" > "${VERSION_FILE}"
}

##
## -----
##
## version:bump
## Bump sem ver by specifying a level.
## Valid levels are:
## - patch (default)
## - minor
## - major
##
## If you want to update the .version file
## pass the `--write` flag.
## @see https://github.com/fsaintjacques/semver-tool/blob/master/src/semver
##
## @arg 1 {string} [level=patch]
## Outputs:
##   Semver string "$major.$minor.$patch"
##
## @flag --write Will write to .version file
##
function version:bump {

    version:check

    # Default values
    level='patch'
    write_to_file=0

    # Parse options
    while [[ "$#" -gt 0 ]]; do
        case $1 in
            --write)
                write_to_file=1
                shift
            ;;
            patch|minor|major)
                level=$1
                shift
            ;;
            *)
                echo "Invalid option: $1"
                return 2
            ;;
        esac
    done

    # Read contents of version and store in
    IFS='.' read -ra identifiers < "$VERSION_FILE"

    [[ "${#identifiers[@]}" -ne 3 ]] && echo "Invalid semver string" && return 1

    patch=${identifiers[2]}
    minor=${identifiers[1]}
    major=${identifiers[0]}

    case $level in
        patch)
            patch=$((patch+1))
        ;;
        minor)
            minor=$((minor+1))
            patch=0
        ;;
        major)
            major=$((major+1))
            minor=0
            patch=0
        ;;
        *)
            echo "Invalid level passed"
            return 2
    esac

    new_version="$major.$minor.$patch"

    if [[ $write_to_file -eq 1 ]]; then
        echo "$new_version" > "${VERSION_FILE}"
    else
        echo "$new_version"
    fi
}

function version:check {
    if [ ! -f "$VERSION_FILE" ]; then
        echo "0.0.0" > "$VERSION_FILE"
    fi
}

function release:notes:has_content {
    local file=${1}

    if [ -z "${file}" ] || [ ! -f "${file}" ]; then
        return 1
    fi

    awk 'NF { found = 1; exit } END { exit found ? 0 : 1 }' "${file}"
}

function release:notes:assert_temporary {
    local file=${1}

    if [ -z "${file}" ]; then
        return 0
    fi

    if git ls-files --error-unmatch -- "${file}" >/dev/null 2>&1; then
        echo "Release notes file is tracked; refusing to consume it as temporary notes: ${file}" >&2
        echo "Use an ignored scratch file such as .release-notes.md, or set RELEASE_NOTES_FILE to an untracked path." >&2
        return 1
    fi
}

function release:changelog:generate {
    local release_tag=${1}
    local release_notes_file=${2}
    local release_notes

    if release:notes:has_content "${release_notes_file}"; then
        release:notes:assert_temporary "${release_notes_file}" || return 1
        release_notes=$(cat "${release_notes_file}") || return 1
        "${GIT_CLIFF_BIN}" --tag "${release_tag}" --with-tag-message "${release_notes}" --output CHANGELOG.md || return 1
        rm -f "${release_notes_file}" || return 1
        echo "Included and removed temporary release notes: ${release_notes_file}" >&2
        return 0
    fi

    "${GIT_CLIFF_BIN}" --tag "${release_tag}" --output CHANGELOG.md
}

##
## -----
##
## modules:*:sync
##
## Keep nested modules in sync with the root go-messaging release tag.
## Missing modules are skipped so the release task can be adopted before every
## planned module has been implemented.
##
## Arguments:
## @arg 1 {string} tag
## @flag --tidy Run go mod tidy (use after the root tag is published)
function _modules:sync_go_messaging {
    local dir=${1}
    local tag=${2}
    local root_module
    shift 2

    local run_tidy=0
    while [[ "$#" -gt 0 ]]; do
        case "$1" in
            --tidy)
                run_tidy=1
            ;;
        esac
        shift
    done

    if [ -z "${dir}" ] || [ -z "${tag}" ]; then
        return 2
    fi

    if [ ! -f "${dir}/go.mod" ]; then
        return 0
    fi

    root_module=$(_module:path "${SCRIPT_DIR}/go.mod") || return 1
    if [ -z "${root_module}" ]; then
        echo "root module path is required" >&2
        return 1
    fi

    (
        cd "${dir}" &&
        go mod edit \
            -droprequire=github.com/goliatone/go-messaging \
            -require="${root_module}@v${tag}" \
            -dropreplace=github.com/goliatone/go-messaging \
            -dropreplace="${root_module}"
    ) || return 1

    if [ "${run_tidy}" -eq 1 ]; then
        (cd "${dir}" && go mod tidy) || return 1
    fi
}

function modules:valkey:sync {
    local tag=${1}
    shift
    _modules:sync_go_messaging "transport/valkey" "${tag}" "$@"
}

function modules:ws:sync {
    local tag=${1}
    shift
    _modules:sync_go_messaging "transport/ws" "${tag}" "$@"
}

function modules:go-command:sync {
    local tag=${1}
    shift
    _modules:sync_go_messaging "adapters/go-command" "${tag}" "$@"
}

function modules:sync {
    local tag=${1}
    shift
    local dir

    for dir in ${GO_NESTED_MODULES}; do
        _modules:sync_go_messaging "${dir}" "${tag}" "$@" || return 1
    done
}

function _modules:list {
    local dir

    for dir in ${GO_NESTED_MODULES}; do
        if [ -f "${dir}/go.mod" ]; then
            printf '%s\n' "${dir}"
        fi
    done
}

function _modules:stage {
    local dir

    for dir in "$@"; do
        git add "${dir}/go.mod" || return 1
        if [ -f "${dir}/go.sum" ]; then
            git add "${dir}/go.sum" || return 1
        fi
    done
}

function _module:path {
    local module_file=${1}

    awk '$1 == "module" { print $2; exit }' "${module_file}"
}

function _module:required_version {
    local module_file=${1}
    local dependency=${2}

    awk -v dependency="${dependency}" '
        $1 == "require" && $2 == dependency { print $3; exit }
        $1 == dependency { print $2; exit }
    ' "${module_file}"
}

function _release:normalize_version {
    local version=${1#v}

    if [[ ! "${version}" =~ ^(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)(-[0-9A-Za-z.-]+)?(\+[0-9A-Za-z.-]+)?$ ]]; then
        echo "Invalid semantic version: ${1}" >&2
        return 2
    fi

    printf '%s\n' "${version}"
}

function _release:next_patch_version {
    local current="0.0.0"
    local major
    local minor
    local patch

    if [ -s "${VERSION_FILE}" ]; then
        current=$(tr -d '[:space:]' < "${VERSION_FILE}")
    fi
    current=$(_release:normalize_version "${current}") || return 1
    current=${current%%[-+]*}
    IFS='.' read -r major minor patch <<< "${current}"
    printf '%s.%s.%s\n' "${major}" "${minor}" "$((patch + 1))"
}

function _release:assert_semantic_import_version {
    local module_file=${1}
    local version=${2}
    local module_path
    local major

    module_path=$(_module:path "${module_file}") || return 1
    major=${version%%.*}

    if [ -z "${module_path}" ]; then
        echo "Missing module path in ${module_file}" >&2
        return 1
    fi

    if [ "${major}" -ge 2 ]; then
        if [[ "${module_path}" != */v${major} ]]; then
            echo "Semantic import-version guard: ${module_path} must end in /v${major} before releasing v${version}" >&2
            return 1
        fi
        return 0
    fi

    if [[ "${module_path}" =~ /v[0-9]+$ ]]; then
        echo "Semantic import-version guard: ${module_path} must not use a major suffix for v${version}" >&2
        return 1
    fi
}

function _release:assert_module_versions {
    local version=${1}
    local module_dir

    _release:assert_semantic_import_version "go.mod" "${version}" || return 1
    while IFS= read -r module_dir; do
        _release:assert_semantic_import_version "${module_dir}/go.mod" "${version}" || return 1
    done < <(_modules:list)
}

function _release:assert_managed_output {
    local path=${1}

    if [ -e "${path}" ] && ! git ls-files --error-unmatch -- "${path}" >/dev/null 2>&1; then
        echo "Untracked release-managed output exists: ${path}" >&2
        echo "Remove it or add a reviewed initial version before releasing." >&2
        return 1
    fi
}

function release:preflight {
    local main_branch="${GIT_MAIN:-main}"
    local current_branch

    current_branch=$(git symbolic-ref --short HEAD) || return 1
    if [[ "${current_branch}" != "${main_branch}" ]]; then
        lgr E "Release must run on ${main_branch}; current branch is ${current_branch}"
        return 1
    fi
    if [ -n "$(git status --porcelain --untracked-files=no)" ]; then
        echo "Tracked working tree changes are present; commit or stash them before release." >&2
        git status --short --untracked-files=no >&2
        return 1
    fi
    _release:assert_managed_output "${VERSION_FILE}" || return 1
    _release:assert_managed_output "CHANGELOG.md" || return 1
    if ! command -v "${GIT_CLIFF_BIN}" >/dev/null 2>&1; then
        echo "git-cliff is required before release: ${GIT_CLIFF_BIN}" >&2
        return 1
    fi
    if ! git remote get-url origin >/dev/null 2>&1; then
        echo "Release remote 'origin' is not configured" >&2
        return 1
    fi
}

##
## -----
##
## release:dry-run
##
## Print and validate the complete release plan without changing files, refs,
## or remotes. The optional version accepts either 1.2.3 or v1.2.3 and defaults
## to the next patch version.
function release:dry-run {
    local requested_version=${1:-}
    local version
    local release_tag
    local module_dir
    local command_version
    local root_module
    local main_branch="${GIT_MAIN:-main}"

    if [ "$#" -gt 1 ]; then
        echo "Usage: $0 release:dry-run [version]" >&2
        return 2
    fi

    if [ -z "${requested_version}" ]; then
        requested_version=$(_release:next_patch_version) || return 1
    fi
    version=$(_release:normalize_version "${requested_version}") || return $?
    release_tag="v${version}"

    _release:assert_module_versions "${version}" || return 1
    root_module=$(_module:path go.mod) || return 1

    echo "release-tag: ${release_tag}"
    echo "root-module: ${root_module}"

    while IFS= read -r module_dir; do
        echo "root-requirement: ${module_dir} ${root_module}@${release_tag}"
        echo "removed-replacement: ${module_dir} ${root_module}"
        if [ "${module_dir}" = "adapters/go-command" ]; then
            command_version=$(_module:required_version "${module_dir}/go.mod" "github.com/goliatone/go-command")
            if [ -z "${command_version}" ]; then
                echo "Missing github.com/goliatone/go-command requirement in ${module_dir}/go.mod" >&2
                return 1
            fi
            echo "preserved-requirement: ${module_dir} github.com/goliatone/go-command@${command_version}"
        fi
        echo "module-tag: ${module_dir}/${release_tag}"
    done < <(_modules:list)

    echo "atomic-push-ref: HEAD:${main_branch}"
    echo "atomic-push-ref: refs/tags/${release_tag}"
    while IFS= read -r module_dir; do
        echo "atomic-push-ref: refs/tags/${module_dir}/${release_tag}"
    done < <(_modules:list)
}


##
## -----
##
## release
##
## Bump our current version, create a git tag
## and push to trigger our release flow.
##
## Arguments:
## @arg 1 {string} [level=patch]
##        Accepted major, minor, patch
function release {
    local tag
    local level
    local message
    local release_tag
    local main_branch="${GIT_MAIN:-main}"
    local release_notes_file
    local release_notes_enabled
    local module_dir
    local module_tag
    local command_version_before
    local command_version_after
    local -a module_dirs
    local -a push_refs

    level=""
    message=""
    release_notes_file="${RELEASE_NOTES_FILE:-.release-notes.md}"
    release_notes_enabled=1

    while [[ "$#" -gt 0 ]]; do
        case "$1" in
            patch|minor|major)
                if [ -n "${level}" ]; then
                    echo "Release level specified more than once" >&2
                    return 2
                fi
                level=$1
                shift
            ;;
            --notes|--notes-file)
                shift
                if [ -z "${1:-}" ]; then
                    echo "--notes requires a file path" >&2
                    return 2
                fi
                release_notes_file=$1
                shift
            ;;
            --no-release-notes)
                release_notes_enabled=0
                shift
            ;;
            --)
                shift
                while [[ "$#" -gt 0 ]]; do
                    if [ -z "${message}" ]; then
                        message=$1
                    else
                        message="${message} $1"
                    fi
                    shift
                done
            ;;
            -*)
                echo "Invalid release option: $1" >&2
                return 2
            ;;
            *)
                if [ -z "${message}" ]; then
                    message=$1
                else
                    message="${message} $1"
                fi
                shift
            ;;
        esac
    done

    level=${level:-"patch"}

    release:preflight || return 1

    git fetch origin "${main_branch}" --tags || return 1
    git merge --ff-only "origin/${main_branch}" || return 1

    tag=$(version:bump "${level}") || return 1
    release_tag="v${tag}"

    _release:assert_module_versions "${tag}" || return 1

    if git rev-parse -q --verify "refs/tags/${release_tag}" >/dev/null; then
        echo "Release tag already exists: ${release_tag}" >&2
        return 1
    fi

    while IFS= read -r module_dir; do
        module_dirs+=("${module_dir}")
        module_tag="${module_dir}/${release_tag}"
        if git rev-parse -q --verify "refs/tags/${module_tag}" >/dev/null; then
            echo "Nested module release tag already exists: ${module_tag}" >&2
            return 1
        fi
    done < <(_modules:list)

    message=${message:-"New ${level} release: ${release_tag}"}

    if [ -f "adapters/go-command/go.mod" ]; then
        command_version_before=$(_module:required_version "adapters/go-command/go.mod" "github.com/goliatone/go-command")
        if [ -z "${command_version_before}" ]; then
            echo "Missing github.com/goliatone/go-command requirement in adapters/go-command/go.mod" >&2
            return 1
        fi
    fi

    version:set "${tag}" || return 1
    modules:sync "${tag}" || return 1

    if [ -n "${command_version_before}" ]; then
        command_version_after=$(_module:required_version "adapters/go-command/go.mod" "github.com/goliatone/go-command")
        if [ "${command_version_after}" != "${command_version_before}" ]; then
            echo "Release sync changed go-command from ${command_version_before} to ${command_version_after}; refusing release" >&2
            return 1
        fi
    fi

    if [ "${release_notes_enabled}" -eq 1 ]; then
        release:changelog:generate "${release_tag}" "${release_notes_file}" || return 1
    else
        "${GIT_CLIFF_BIN}" --tag "${release_tag}" --output CHANGELOG.md || return 1
    fi

    git add "${VERSION_FILE}" CHANGELOG.md || return 1
    _modules:stage "${module_dirs[@]}" || return 1
    git commit -m "Bump version: ${release_tag}" || return 1

    git tag -a "${release_tag}" -m "${message}" || return 1

    for module_dir in "${module_dirs[@]}"; do
        module_tag="${module_dir}/${release_tag}"
        git tag -a "${module_tag}" -m "${module_dir} release: ${release_tag}" || return 1
    done

    push_refs=("HEAD:${main_branch}" "refs/tags/${release_tag}")
    for module_dir in "${module_dirs[@]}"; do
        push_refs+=("refs/tags/${module_dir}/${release_tag}")
    done

    git push --atomic origin "${push_refs[@]}" || return 1
}

